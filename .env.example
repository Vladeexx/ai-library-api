APP_NAME=AI Library API
DEBUG=true  # set to false in production; enables auto table creation on startup

# Async PostgreSQL URL (used by SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://library:library@localhost:5432/library

# PostgreSQL credentials (used by docker-compose to provision the db service)
POSTGRES_USER=library
POSTGRES_PASSWORD=library
POSTGRES_DB=library

REDIS_URL=redis://localhost:6379/0
